# Feloxi — Celery Monitoring
# Copy this file to .env and customize as needed.
# All values below work out of the box with `docker compose up`.

# API Server
PORT=8080
DATABASE_URL=postgres://fp:feloxi@localhost:5432/feloxi
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=feloxi
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-this-to-a-secure-secret-in-production
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
RUST_LOG=api=info,tower_http=info
ALLOW_SIGNUP=false

# Set to true to disable the Swagger UI in production
# DISABLE_SWAGGER=true

# Frontend (server-side only — proxied via Next.js rewrites)
API_URL=http://localhost:8080

# ── Performance Tuning (optional) ────────────────────────
# FP_PG_MAX_CONNECTIONS=50
# FP_REDIS_POOL_SIZE=50
# FP_PUBSUB_CHANNEL_CAPACITY=10000
# FP_FLUSH_INTERVAL_SECS=1
# FP_DRAIN_INTERVAL_SECS=30
# FP_DRAIN_MAX_MESSAGES=500
# FP_STATS_INTERVAL_SECS=30
# FP_TASK_BATCH_SIZE=100
# FP_WORKER_BATCH_SIZE=20
