# ── Stage 1: Build ───────────────────────────────────────────────────
FROM node:22-alpine AS builder
WORKDIR /app
RUN corepack enable

# Install dependencies (cached layer)
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY apps/web/package.json apps/web/
RUN pnpm install --frozen-lockfile

# Build — API_URL must be set at build time for Next.js rewrites (standalone mode bakes them in)
COPY apps/web/ apps/web/
ARG API_URL=http://api:8080
ENV API_URL=${API_URL}
RUN pnpm --filter web build

# ── Stage 2: Runtime ─────────────────────────────────────────────────
FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production

RUN addgroup --system --gid 1001 feloxi && \
    adduser --system --uid 1001 feloxi

# Next.js standalone output in a monorepo preserves the full directory tree:
#   .next/standalone/apps/web/server.js  (entry point)
#   .next/standalone/node_modules/       (pruned dependencies)
COPY --from=builder --chown=feloxi:feloxi /app/apps/web/.next/standalone ./
COPY --from=builder --chown=feloxi:feloxi /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=feloxi:feloxi /app/apps/web/public ./apps/web/public

USER feloxi
EXPOSE 3000
ENV HOSTNAME="0.0.0.0"
CMD ["node", "apps/web/server.js"]
