<clickhouse>
    <logger>
        <level>warning</level>
        <console>true</console>
    </logger>
    <listen_host>::</listen_host>
    <http_port>8123</http_port>
    <tcp_port>9000</tcp_port>
    <max_connections>100</max_connections>
    <max_concurrent_queries>50</max_concurrent_queries>

    <!--
      Disk-full guard (the disk-full incident fix).
      Reject INSERTs with a clean, retryable NOT_ENOUGH_SPACE error while ~5%
      headroom remains, instead of letting the disk hit 100%. A 100%-full
      ClickHouse is hard to recover: merges and ALTER ... DELETE mutations
      themselves need free scratch space, so you can deadlock. Keeping headroom
      means DROP PARTITION / merges can still run during recovery. The buffered
      events wait in the Redis retry queue and replay once space is freed.
      (min_free_disk_ratio_to_perform_insert added in ClickHouse 24.10+.)
    -->
    <merge_tree>
        <min_free_disk_ratio_to_perform_insert>0.05</min_free_disk_ratio_to_perform_insert>
        <!-- Bound a single merge's transient scratch space so one large merge
             can't itself exhaust a small disk. Tune up on large volumes. -->
        <max_bytes_to_merge_at_max_space_in_pool>10737418240</max_bytes_to_merge_at_max_space_in_pool>
    </merge_tree>

    <!-- Cap system log tables to prevent disk fill (3 days, flush every 30s) -->
    <text_log>
        <database>system</database>
        <table>text_log</table>
        <flush_interval_milliseconds>30000</flush_interval_milliseconds>
        <ttl>event_date + INTERVAL 3 DAY</ttl>
    </text_log>
    <trace_log>
        <database>system</database>
        <table>trace_log</table>
        <flush_interval_milliseconds>30000</flush_interval_milliseconds>
        <ttl>event_date + INTERVAL 3 DAY</ttl>
    </trace_log>
    <query_log>
        <database>system</database>
        <table>query_log</table>
        <flush_interval_milliseconds>30000</flush_interval_milliseconds>
        <ttl>event_date + INTERVAL 3 DAY</ttl>
    </query_log>
    <metric_log>
        <database>system</database>
        <table>metric_log</table>
        <flush_interval_milliseconds>30000</flush_interval_milliseconds>
        <ttl>event_date + INTERVAL 3 DAY</ttl>
    </metric_log>
    <asynchronous_metric_log>
        <database>system</database>
        <table>asynchronous_metric_log</table>
        <flush_interval_milliseconds>60000</flush_interval_milliseconds>
        <ttl>event_date + INTERVAL 3 DAY</ttl>
    </asynchronous_metric_log>
    <part_log>
        <database>system</database>
        <table>part_log</table>
        <flush_interval_milliseconds>30000</flush_interval_milliseconds>
        <ttl>event_date + INTERVAL 3 DAY</ttl>
    </part_log>
    <users>
        <default>
            <password></password>
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
            <access_management>1</access_management>
        </default>
    </users>
</clickhouse>
