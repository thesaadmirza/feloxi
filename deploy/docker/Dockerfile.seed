FROM python:3.12-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        postgresql-client \
        redis-tools \
        curl \
    && rm -rf /var/lib/apt/lists/* \
    && pip install --no-cache-dir argon2-cffi

WORKDIR /seed
COPY scripts/seed-demo.py /seed/seed-demo.py

ENTRYPOINT ["python3", "/seed/seed-demo.py"]
